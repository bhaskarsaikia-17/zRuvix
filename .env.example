# zRuvix configuration — copy to .env and fill in your values.
# Real environment variables (systemd / shell exports) override these.

# --- Required for presence tracking ---
# Discord bot token. The bot needs PRESENCE INTENT and SERVER MEMBERS INTENT
# enabled in the Discord Developer Portal.
BOT_TOKEN=

# --- Redis ---
# Connection string. If unset, zRuvix falls back to redis://REDIS_HOST:6379,
# and REDIS_HOST defaults to "localhost".
# Checked in order: REDIS_DSN, REDIS_URI, REDIS_URL.
REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost

# --- HTTP server ---
PORT=4001
# Public base URL, used in bot messages / API key DMs.
EXTERNAL_URL=http://127.0.0.1:4001

# --- Discord bot ---
# Command prefix for KV commands (.set/.get/.del/.kv/.apikey).
COMMAND_PREFIX=.
# Presence shown by the bot account.
BOT_PRESENCE=you <3
# Activity type: 0=Playing 1=Streaming 2=Listening 3=Watching.
BOT_PRESENCE_TYPE=3
# Set to "true" so this instance handles bot commands. Leave false if running
# multiple instances to avoid duplicate command handling.
IS_IDEMPOTENT=true
